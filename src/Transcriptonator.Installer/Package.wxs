<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Transcriptonator"
           Manufacturer="Transcriptonator"
           Version="1.1.0.0"
           UpgradeCode="6B29FC40-CA47-1067-B31D-00DD010662DA">

    <Launch Condition="VersionNT64" Message="Transcriptonator requires a 64-bit version of Windows." />
    <Launch Condition="VersionNT &gt;= 603" Message="Transcriptonator requires Windows 10 or later." />

    <Icon Id="AppIcon.ico" SourceFile="..\Transcriptonator\Assets\app.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Main" Title="Transcriptonator" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="ApplicationShortcut" />
    </Feature>
  </Package>

  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="!(bindpath.Transcriptonator)\**" />
    </ComponentGroup>
  </Fragment>
</Wix>
